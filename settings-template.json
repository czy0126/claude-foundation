{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "",
  "alwaysThinkingEnabled": false,
  "effortLevel": "high",
  "outputStyle": "Explanatory",
  "autoCompactEnabled": true,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(conda *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.anthropic.com)",
      "WebFetch(domain:*.pypi.org)",
      "WebFetch(domain:*.npmjs.com)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push --delete *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(format C:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*-key.json)",
      "Read(./**/credentials)",
      "Read(./**/private.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Edit(./**/*.pem)",
      "Edit(./**/credentials)",
      "Edit(./**/private.key)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(terraform *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject-git-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-destructive.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/protect-sensitive.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | python -c \"import json,sys;print(json.load(sys.stdin).get('tool_input',{}).get('file_path',''))\" 2>/dev/null || { echo \"$INPUT\" | jq -r '.tool_input.file_path // empty' 2>/dev/null; }); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -q '\\.py$'; then ruff check --fix \"$FILE\" 2>&1 || true; fi",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "BRANCH=\"$(git branch --show-current 2>/dev/null || echo N/A)\"; if command -v jq >/dev/null 2>&1; then jq -n --arg branch \"$BRANCH\" '{continue: true, systemMessage: (\"压缩完成。当前分支: \" + $branch + \"。关键约束：两次修复失败→停止重新分析。已知陷阱在项目 CLAUDE.md 第五节。\")}'; else python -c \"import json;print(json.dumps({'continue':True,'systemMessage':f'压缩完成。当前分支: $BRANCH。关键约束：两次修复失败→停止重新分析。已知陷阱在项目 CLAUDE.md 第五节。'}))\"; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "command -v jq >/dev/null 2>&1 && jq -r '[.model.display_name, \" | \", (.context_window.used_percentage|tostring) + \"%\", \" | $\", (.cost.total_cost_usd // 0 | tostring), \" | \", .workspace.current_dir] | join(\"\")' || python -c \"import json,sys;d=json.load(sys.stdin);m=d.get('model',{});c=d.get('context_window',{});x=d.get('cost',{});w=d.get('workspace',{});print(m.get('display_name','?')+' | '+str(int(c.get('used_percentage',0)))+'% | $'+str(round(x.get('total_cost_usd',0),2))+' | '+w.get('current_dir','?'))\" 2>/dev/null || echo '...'",
    "padding": 2,
    "refreshInterval": 5
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  }
}